  "item": [
    {
      "name": "Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const cookies = pm.cookies;\r",
              "\r",
              "const bpmcsrf = cookies.get(\"BPMCSRF\");\r",
              "const aspxauth = cookies.get(\".ASPXAUTH\");\r",
              "\r",
              "if (bpmcsrf) {\r",
              "    pm.collectionVariables.set(\"BPMCSRF\", bpmcsrf);\r",
              "    console.log(\"BPMCSRF saved:\", bpmcsrf);\r",
              "} else {\r",
              "    console.warn(\"BPMCSRF not found\");\r",
              "}\r",
              "\r",
              "if (aspxauth) {\r",
              "    pm.collectionVariables.set(\"ASPXAUTH\", aspxauth);\r",
              "    console.log(\".ASPXAUTH saved:\", aspxauth);\r",
              "} else {\r",
              "    console.warn(\".ASPXAUTH not found\");\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
